Options -Indexes

# Enable URL rewriting
RewriteEngine On

# Allow direct access to real files (uploads, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else through index.php
RewriteRule ^ index.php [QSA,L]

# CORS preflight (backup — also handled in PHP)
<IfModule mod_headers.c>
    SetEnvIf Origin "^http://(localhost|127\.0\.0\.1):(5173|3000)$" CORS_ORIGIN=$0
    Header always set Access-Control-Allow-Origin "%{CORS_ORIGIN}e" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Origin "*" env=!CORS_ORIGIN
    Header always set Access-Control-Allow-Methods "GET, POST, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
    Header always set Access-Control-Allow-Credentials "true"
    Header always set Vary "Origin"
</IfModule>

# PHP settings for WAMP
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 30
</IfModule>
